body{
    background:#0b0f19;
    color:white;
    font-family:Arial;
    text-align:center;
}

button{
    padding:12px;
    margin:6px;
    font-size:16px;
    border-radius:10px;
    border:none;
    background:#00e5ff;
    cursor:pointer;
}

#chat{
    width:85%;
    height:300px;
    margin:auto;
    background:rgba(255,255,255,0.05);
    border:1px solid #00e5ff;
    padding:10px;
    overflow:auto;
    text-align:left;
    border-radius:12px;
}
